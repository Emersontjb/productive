{
    /*
     =====================================================================
     MANIFEST.JSON - ARQUIVO DE CONFIGURAÇÃO PWA
     =====================================================================
     
     Este arquivo define as configurações do app para que ele
     possa ser instalado como um app nativo no dispositivo.
     
     O QUE CADA CAMPO SIGNIFICA:
     - name: Nome completo do app (exibido na loja de apps)
     - short_name: Nome curto (exibido na tela inicial)
     - description: Descrição do app
     - start_url: Página inicial (sempre "/")
     - display: Como o app deve abrir
       * "standalone": Abre como app nativo (sem navegador)
     - background_color: Cor de fundo quando o app carrega
     - theme_color: Cor da barra de status e tema
     - icons: Ícones do app em diferentes tamanhos
     
     INSTALANDO O APP NO ANDROID:
     1. Abra o app no Chrome
     2. Vá em menu > "Adicionar à tela inicial"
     3. O app será instalada como um ícone na home
     
     INSTALANDO NO iOS:
     1. Abra no Safari
     2. Toque em compartilhar > "Adicionar à Tela de Início"
     
     =====================================================================
     */
    "name": "Produtive - Organize Sua Vida",
    "short_name": "Produtive",
    "description": "App de produtividade completo com tarefas, notas e agenda",
    "start_url": "/",
    "display": "standalone",
    "background_color": "#f8fafc",
    "theme_color": "#6366f1",
    "icons": [
        {
            "src": "data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><rect fill='%236366f1' width='100' height='100' rx='20'/><text x='50' y='65' font-size='50' text-anchor='middle' fill='white'>⚡</text></svg>",
            "sizes": "192x192",
            "type": "image/svg+xml"
        },
        {
            "src": "data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><rect fill='%236366f1' width='100' height='100' rx='20'/><text x='50' y='65' font-size='50' text-anchor='middle' fill='white'>⚡</text></svg>",
            "sizes": "512x512",
            "type": "image/svg+xml"
        }
    ]
}